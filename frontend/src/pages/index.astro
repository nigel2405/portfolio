---
import Layout from '../layouts/Layout.astro';
import ScrollHero from '../components/ScrollHero.jsx';
import BentoGridDashboard from '../components/BentoGridDashboard.jsx';
import Skills from '../components/Skills.jsx';
import ProjectsGrid from '../components/ProjectsGrid.jsx';
import TerminalApp from '../components/TerminalApp.jsx';
import JarvisAssistant from '../components/JarvisAssistant.jsx';
import GithubStats from '../components/GithubStats.jsx';

import ProjectsSection from '../components/ProjectsSection.jsx';
import GithubSection from '../components/GithubSection.jsx';
import LinkedinSection from '../components/LinkedinSection.jsx';
import ContactSection from '../components/ContactSection.jsx';
---

<Layout title="Nigel Shivalkar | Developer Portfolio">
	<main class="relative w-full min-h-screen pb-20 bg-[#150522]">
		{/* New Scroll Animated Intro Hero */}
		<ScrollHero client:load />
		
		{/* Core Dashboard Grid */}
		<div class="container mx-auto px-4 py-8 relative z-10 flex flex-col gap-6 max-w-6xl -mt-32">
			<BentoGridDashboard client:visible>
				<Skills />
				<ProjectsGrid />
				<GithubStats />
				<JarvisAssistant />
				<TerminalApp />
			</BentoGridDashboard>
		</div>

		{/* Full-Page Sections */}
		<ProjectsSection client:visible />
		<GithubSection client:visible />
		<LinkedinSection client:visible />
		<ContactSection client:visible />
	</main>
</Layout>
